DATABASE_URL="postgresql://postgres:password@localhost:5432/support_tickets?schema=public"
# For local development with SQLite:
# DATABASE_URL="file:./dev.db"

## REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
## DO NOT reuse these placeholder strings in any environment.
JWT_SECRET="REPLACE_ME_WITH_A_64_CHAR_RANDOM_HEX_STRING"
JWT_REFRESH_SECRET="REPLACE_ME_WITH_ANOTHER_64_CHAR_RANDOM_HEX_STRING"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
PORT=3001

## Logging — LOW (verbose) | MEDIUM | HIGH | FATAL
LOG_LEVEL=LOW
LOG_TO_FILE=true

# Meilisearch (optional — system falls back to DB search if unavailable)
MEILI_HOST="http://localhost:7700"
MEILI_API_KEY="your-meilisearch-key"

# ─── Email (SMTP) ────────────────────────────────────────────
# Email is configured per-organization via the admin UI (Settings → Email).
# Below are example values for reference.
#
# Option 1: Ethereal (FREE — dev/testing, emails captured not delivered)
#   Use POST /api/v1/email-config/setup-ethereal to auto-generate credentials
#   SMTP_HOST="smtp.ethereal.email"
#   SMTP_PORT=587
#
# Option 2: Brevo/Sendinblue (FREE — 300 emails/day)
#   SMTP_HOST="smtp-relay.brevo.com"
#   SMTP_PORT=587
#
# Option 3: Gmail (FREE — 500 emails/day, requires App Password)
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT=587
#
# Option 4: Mailtrap (FREE — 100 emails/month, testing only)
#   SMTP_HOST="sandbox.smtp.mailtrap.io"
#   SMTP_PORT=2525
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="support@yourdomain.com"

# ─── S3 / File Storage ───────────────────────────────────────
AWS_S3_BUCKET="support-ticket-uploads"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Frontend URL (for CORS) ─────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── Channel Integrations (configured per-org via admin UI) ──
# These are NOT env vars — they are stored in the database per organization.
# Configure via Settings → Channels in the web UI.
#
# Twilio (FREE trial: $15.50 credit, WhatsApp sandbox is free)
#   Account SID & Auth Token: https://console.twilio.com
#   WhatsApp Sandbox: Console → Messaging → Try it Out → WhatsApp
#
# Meta WhatsApp Cloud API (FREE: 1000 conversations/month)
#   Setup: https://developers.facebook.com → Create App → Add WhatsApp
#
# Inbound Email / IMAP (FREE with Gmail or Outlook)
#   Gmail: imap.gmail.com:993 (enable IMAP + App Password)
#   Outlook: outlook.office365.com:993
#
# For local webhook testing, use ngrok (free):
#   ngrok http 3001
#   Use the https URL for Twilio/Meta webhook configuration
