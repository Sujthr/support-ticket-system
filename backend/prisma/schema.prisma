generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ORGANIZATIONS (TENANTS) ────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  logo      String?
  plan      String   @default("FREE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  tickets       Ticket[]
  slaPolicies   SlaPolicy[]
  tags          Tag[]
  articles      Article[]
  categories    ArticleCategory[]
  notifications Notification[]
  jiraConfig    JiraConfig?

  @@map("organizations")
}

// ─── USERS ──────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  avatar         String?
  role           String    @default("END_USER")
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  organizationId String    @map("organization_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdTickets    Ticket[]       @relation("TicketCreator")
  assignedTickets   Ticket[]       @relation("TicketAssignee")
  comments          Comment[]
  notifications     Notification[] @relation("NotificationRecipient")
  activityLogs      ActivityLog[]
  refreshTokens     RefreshToken[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@index([email])
  @@map("users")
}

// ─── REFRESH TOKENS ─────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── TICKETS ────────────────────────────────────────────────

model Ticket {
  id              String    @id @default(uuid())
  ticketNumber    Int       @map("ticket_number")
  title           String
  description     String
  priority        String    @default("MEDIUM")
  status          String    @default("OPEN")
  organizationId  String    @map("organization_id")
  creatorId       String    @map("creator_id")
  assigneeId      String?   @map("assignee_id")
  slaPolicyId     String?   @map("sla_policy_id")
  slaBreached     Boolean   @default(false) @map("sla_breached")
  dueAt           DateTime? @map("due_at")
  resolvedAt      DateTime? @map("resolved_at")
  closedAt        DateTime? @map("closed_at")
  firstResponseAt DateTime? @map("first_response_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  jiraIssueKey  String?  @map("jira_issue_key")
  jiraIssueUrl  String?  @map("jira_issue_url")
  jiraStatus    String?  @map("jira_status")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation("TicketCreator", fields: [creatorId], references: [id])
  assignee     User?        @relation("TicketAssignee", fields: [assigneeId], references: [id])
  slaPolicy    SlaPolicy?   @relation(fields: [slaPolicyId], references: [id])
  comments     Comment[]
  attachments  Attachment[]
  tags         TicketTag[]
  activityLogs ActivityLog[]

  @@unique([ticketNumber, organizationId])
  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([createdAt])
  @@index([organizationId, status])
  @@index([organizationId, assigneeId])
  @@map("tickets")
}

// ─── COMMENTS ───────────────────────────────────────────────

model Comment {
  id         String   @id @default(uuid())
  body       String
  isInternal Boolean  @default(false) @map("is_internal")
  ticketId   String   @map("ticket_id")
  authorId   String   @map("author_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])
  attachments Attachment[]

  @@index([ticketId])
  @@index([authorId])
  @@map("comments")
}

// ─── ATTACHMENTS ────────────────────────────────────────────

model Attachment {
  id        String   @id @default(uuid())
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type")
  ticketId  String?  @map("ticket_id")
  commentId String?  @map("comment_id")
  createdAt DateTime @default(now()) @map("created_at")

  ticket  Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([commentId])
  @@map("attachments")
}

// ─── TAGS ───────────────────────────────────────────────────

model Tag {
  id             String   @id @default(uuid())
  name           String
  color          String   @default("#6B7280")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      TicketTag[]

  @@unique([name, organizationId])
  @@map("tags")
}

model TicketTag {
  ticketId String @map("ticket_id")
  tagId    String @map("tag_id")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@map("ticket_tags")
}

// ─── SLA POLICIES ───────────────────────────────────────────

model SlaPolicy {
  id                   String   @id @default(uuid())
  name                 String
  description          String?
  priority             String
  firstResponseMinutes Int      @map("first_response_minutes")
  resolutionMinutes    Int      @map("resolution_minutes")
  organizationId       String   @map("organization_id")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@unique([priority, organizationId])
  @@index([organizationId])
  @@map("sla_policies")
}

// ─── ACTIVITY LOG ───────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────

model Notification {
  id             String   @id @default(uuid())
  type           String
  title          String
  message        String
  isRead         Boolean  @default(false) @map("is_read")
  recipientId    String   @map("recipient_id")
  organizationId String   @map("organization_id")
  metadata       String?
  createdAt      DateTime @default(now()) @map("created_at")

  recipient    User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead])
  @@index([organizationId])
  @@map("notifications")
}

// ─── KNOWLEDGE BASE ─────────────────────────────────────────

model ArticleCategory {
  id             String   @id @default(uuid())
  name           String
  slug           String
  description    String?
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  articles     Article[]

  @@unique([slug, organizationId])
  @@map("article_categories")
}

model Article {
  id             String   @id @default(uuid())
  title          String
  slug           String
  content        String
  isPublished    Boolean  @default(false) @map("is_published")
  categoryId     String   @map("category_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category     ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([slug, organizationId])
  @@index([organizationId, isPublished])
  @@map("articles")
}

// ─── JIRA INTEGRATION ───────────────────────────────────────

model JiraConfig {
  id             String   @id @default(uuid())
  baseUrl        String   @map("base_url")
  email          String
  apiToken       String   @map("api_token")
  projectKey     String   @map("project_key")
  issueType      String   @default("Task") @map("issue_type")
  isActive       Boolean  @default(true) @map("is_active")
  organizationId String   @unique @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("jira_configs")
}
